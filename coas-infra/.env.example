# CoAS stack — environment template.
#
# Copy to .env and fill in. Most values have sensible defaults; only the
# secrets really need to be set, and those should ideally come from your
# secret store via scripts/coas-up rather than this file.
#
#   cp .env.example .env && chmod 600 .env
#
# .env is gitignored. Never commit it.

# ── Secrets (RECOMMENDED: use coas-secrets, not this file) ──────
# If you set these here, they're persisted on disk in plaintext.
# The coas-up wrapper reads them from your platform's secret store
# (macOS Keychain or Linux pass) and exports them at runtime — that
# path doesn't need them in .env at all.
#
# Only uncomment these if you can't or won't use the secret store.

# MATRIX_ACCESS_TOKEN=syt_paste_token_here
# MATRIX_RECOVERY_PASSPHRASE=optional_secure_backup_passphrase
# TS_AUTHKEY=tskey-auth-paste-key-here

# ── Tailscale node identity ─────────────────────────────────────
# The hostname this node will be reachable as on your tailnet.
# Combined with your tailnet name to form the full DNS name (TS_FQDN).
TS_HOSTNAME=coas-matrix

# Full tailnet hostname — used by Caddy as the TLS certificate name
# and as the public-facing URL in .well-known/matrix/client.
# Find your tailnet's MagicDNS name in the Tailscale admin console.
# Example: coas-matrix.tail12345.ts.net
TS_FQDN=coas-matrix.CHANGE-ME.ts.net

# ── Bind mount paths ────────────────────────────────────────────
# The git workspace root is bind-mounted at /workspace inside the
# coas-agent container. The chief of staff can reach any repo under
# this path, e.g. /workspace/coas, /workspace/tools-and-skills,
# /workspace/personal-research. No system files outside ~/git/ are
# bind-mounted.
#
# Override only if your git workspace lives somewhere other than ~/git/.

# GIT_ROOT=/Users/jim/git

# ── Pi state directory ──────────────────────────────────────────
# Bind-mounted into the coas-agent container at /home/coas/.pi.
# Contains the agent registry, kanban state, memories, sessions,
# and the matrix crypto store. Survives container rebuilds.
# PI_STATE_DIR=/Users/jim/.pi

# ── Kanban tuning ───────────────────────────────────────────────
KANBAN_WIP_LIMIT=3
