# Caddyfile for the CoAS Matrix stack.
#
# Caddy sits behind tailscale serve and:
#   1. Serves /.well-known/matrix/{client,server} as static JSON pointing
#      at the tailnet hostname — Element X and other Matrix clients fetch
#      these on first sign-in to discover the homeserver base URL.
#      Continuwuity's built-in .well-known support is brittle.
#   2. Reverse-proxies /_matrix/* and /_synapse/* to continuwuity:8008
#   3. Acts as a blast-isolation buffer between malformed HTTP and the
#      Continuwuity process.
#
# TLS termination is handled by `tailscale serve --https=443 http://127.0.0.1:80`
# (set up once via `docker exec` against the running tailscale container,
# persisted in the tailscale-state volume). Tailscale serve fetches a real
# TLS cert for the *.ts.net hostname from tailscaled and proxies to Caddy
# on plain HTTP. We tried using Caddy's built-in get_certificate tailscale
# directive but it didn't reliably bypass Caddy's ACME fallback, which
# fails NXDOMAIN against *.ts.net hostnames (they resolve only over
# MagicDNS, not public DNS).
#
# Caddy runs in tailscale's network namespace via `network_mode:
# service:tailscale` in docker-compose, so:
#   - tailscale serve and Caddy share the same loopback (the proxy uses
#     127.0.0.1:80 which resolves inside the shared netns)
#   - Caddy inherits tailscale's coas-net access and reaches Continuwuity
#     via docker DNS as `continuwuity:8008`
#
# Required environment variables (passed in via docker-compose):
#   TS_FQDN — full tailnet hostname e.g. coas-matrix.tail12345.ts.net
#   (substituted into the .well-known/matrix/client base_url JSON)
{
	# Caddy serves plain HTTP on :80 inside tailscale's netns. TLS
	# termination is handled by `tailscale serve --https=443` which
	# proxies inbound HTTPS connections from the tailnet to this
	# HTTP listener. We tried using Caddy's `get_certificate tailscale`
	# directive but it didn't reliably bypass Caddy's ACME fallback,
	# which fails NXDOMAIN against *.ts.net hostnames (they resolve
	# only over MagicDNS, not public DNS).
	#
	# `auto_https off` disables Caddy's automatic cert management
	# entirely. This server is HTTP only.
	auto_https off
	admin off
}

# HTTP listener inside tailscale's netns. tailscale serve fronts this
# with HTTPS:443 using a real tailnet TLS cert.
:80 {

	# ── Discovery (.well-known/matrix/client) ─────────────────────
	# Element X and other Matrix clients fetch this on first sign-in
	# to discover the homeserver base URL. Returning an explicit
	# JSON pointing at our tailnet hostname avoids any "I can sign
	# in but rooms don't load" failure modes.
	handle /.well-known/matrix/client {
		header {
			Content-Type "application/json"
			Access-Control-Allow-Origin "*"
		}
		respond `{"m.homeserver":{"base_url":"https://{$TS_FQDN}"}}`
	}

	# ── Discovery (.well-known/matrix/server) ─────────────────────
	# We don't federate, so this could 404. We return an empty-but-
	# valid response anyway — defensive for any client/scanner that
	# expects the file to exist.
	handle /.well-known/matrix/server {
		header Content-Type "application/json"
		respond `{}` 200
	}

	# ── Matrix Client-Server API ──────────────────────────────────
	# X-Forwarded-For and X-Forwarded-Proto are passed by reverse_proxy
	# by default. Host needs an explicit override because Caddy's
	# default is to rewrite Host to the upstream's hostname — we want
	# Continuwuity to see the public-facing tailnet hostname so absolute
	# URLs in media uploads, room invites, etc. point to the right place.
	handle /_matrix/* {
		reverse_proxy http://continuwuity:8008 {
			header_up Host {host}
		}
	}

	# ── Continuwuity admin endpoints (if any) ─────────────────────
	handle /_synapse/* {
		reverse_proxy http://continuwuity:8008 {
			header_up Host {host}
		}
	}

	# ── Catch-all ─────────────────────────────────────────────────
	handle {
		respond "CoAS Matrix homeserver — private island, no public access" 200
	}

	# ── Logging ───────────────────────────────────────────────────
	log {
		output stdout
		format console
		level INFO
	}
}
