{
  "name": "coas-kanban",
  "displayName": "CoAS Kanban Board",
  "description": "Live kanban board panel for CoAS — reads board.log, auto-refreshes on changes",
  "version": "0.1.0",
  "publisher": "coas",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "coas.openKanban",
        "title": "CoAS: Open Kanban Board"
      }
    ]
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "npm run build -- --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.0"
  }
}
