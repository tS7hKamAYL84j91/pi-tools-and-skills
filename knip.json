{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "extensions/*/index.ts",
    "project-extensions/*/index.ts",
    "vscode-extension/src/extension.ts",
    "lib/*.ts",
    "lib/**/*.ts",
    "scripts/*.ts"
  ],
  "project": [
    "extensions/**/*.ts",
    "project-extensions/**/*.ts",
    "vscode-extension/**/*.ts",
    "lib/**/*.ts",
    "scripts/**/*.ts"
  ],
  "ignoreDependencies": [
    "@mariozechner/pi-tui",
    "@vitest/coverage-v8",
    "vscode"
  ],
  "tags": [
    "-lintignore"
  ]
}
