#!/usr/bin/env bash
set -euo pipefail

# setup-pi-clean — remove this reusable pi package registration.
#
# Also removes legacy direct registrations written by older setup flows.
# It intentionally does not remove models.json, shell hooks, provider config,
# Matrix secrets, or OpenRouter secrets. Those are runtime concerns owned by CoAS.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PI_TOOLS_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
SETTINGS_JSON="$HOME/.pi/agent/settings.json"

bold()  { printf '\033[1m%s\033[0m\n' "$*"; }
green() { printf '\033[32m%s\033[0m\n' "$*"; }
red()   { printf '\033[31m%s\033[0m\n' "$*"; }
dim()   { printf '\033[2m%s\033[0m\n' "$*"; }

usage() {
	cat <<'HELP'
Usage: setup-pi-clean

Removes pi-tools-and-skills package, memory, and legacy direct registrations.
Runtime cleanup belongs in ~/git/coas.
HELP
}

for arg in "$@"; do
	case "$arg" in
		-h|--help)
			usage
			exit 0
			;;
		*)
			red "Error: Unknown argument: $arg"
			usage
			exit 1
			;;
	esac
done

if ! command -v python3 &>/dev/null; then
	red "Error: python3 not found."
	exit 1
fi

bold "── Remove pi-tools-and-skills package registration ──"

if [[ ! -f "$SETTINGS_JSON" ]]; then
	dim "  $SETTINGS_JSON not found (skipping)"
	exit 0
fi

python3 - "$SETTINGS_JSON" "$PI_TOOLS_DIR" "$PI_TOOLS_DIR/skills" "$PI_TOOLS_DIR/extensions" "$PI_TOOLS_DIR/prompts" "$PI_TOOLS_DIR/memories" <<'PY'
import json
import os
import sys

settings_path = sys.argv[1]
package_dir = sys.argv[2]
skills_dir = sys.argv[3]
ext_dir = sys.argv[4]
prompts_dir = sys.argv[5]
memories_dir = sys.argv[6]
legacy_package_dir = package_dir.replace('/pi-tools-and-skills', '/tools-and-skills')

with open(settings_path, 'r') as handle:
    settings = json.load(handle)


def legacy_path(path: str) -> str:
    return path.replace('/pi-tools-and-skills/', '/tools-and-skills/')


def set_or_delete_list(key: str, values: list) -> None:
    if values:
        settings[key] = values
    elif key in settings:
        del settings[key]


def remove_listed(key: str, values: set[str]) -> int:
    existing = settings.get(key, [])
    if not isinstance(existing, list):
        return 0
    filtered = [item for item in existing if item not in values]
    set_or_delete_list(key, filtered)
    return len(existing) - len(filtered)

removed_packages = 0
existing_packages = settings.get('packages', [])
if isinstance(existing_packages, list):
    filtered_packages = []
    for entry in existing_packages:
        source = entry.get('source') if isinstance(entry, dict) else entry
        if source in {package_dir, legacy_package_dir}:
            removed_packages += 1
            continue
        filtered_packages.append(entry)
    set_or_delete_list('packages', filtered_packages)

removed_memories = remove_listed('memories', {memories_dir, legacy_path(memories_dir)})
remove_listed('skills', {skills_dir, legacy_path(skills_dir)})
remove_listed('prompts', {prompts_dir, legacy_path(prompts_dir)})
legacy_ext_dir = legacy_path(ext_dir)
remove_listed('extensions', {
    ext_dir,
    legacy_ext_dir,
    os.path.join(ext_dir, 'pi-panopticon'),
    os.path.join(ext_dir, 'pi-cheatsheets'),
    os.path.join(ext_dir, 'machine-memory'),
    os.path.join(ext_dir, 'council'),
    os.path.join(ext_dir, 'kanban'),
    os.path.join(ext_dir, 'matrix'),
    os.path.join(legacy_ext_dir, 'pi-panopticon'),
    os.path.join(legacy_ext_dir, 'pi-cheatsheets'),
    os.path.join(legacy_ext_dir, 'machine-memory'),
    os.path.join(legacy_ext_dir, 'council'),
    os.path.join(legacy_ext_dir, 'kanban'),
    os.path.join(legacy_ext_dir, 'matrix'),
})

with open(settings_path, 'w') as handle:
    json.dump(settings, handle, indent=2)
    handle.write('\n')

print(f'  Removed packages: {removed_packages}')
print(f'  Removed memories: {removed_memories}')
PY

green "  Cleaned $SETTINGS_JSON"
dim "  Runtime settings were left untouched."
