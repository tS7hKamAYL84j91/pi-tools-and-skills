#!/usr/bin/env bash
#
# coas-up — bring up the CoAS stack in one command.
#
# Handles everything:
#   1. Ensures secrets are in the secret store (prompts if missing)
#   2. Ensures .env exists with TS_FQDN
#   3. Starts docker compose services
#   4. Configures Tailscale Serve (HTTPS proxy, idempotent)
#   5. Waits for all services to be healthy
#   6. Auto-bootstraps Matrix accounts on first run
#
# Usage:
#   ./scripts/coas-up                                        # normal start
#   ./scripts/coas-up --build                                # rebuild images
#
# First run (interactive — prompts for everything):
#   ./scripts/coas-up
#
# First run (non-interactive, CLI args):
#   ./scripts/coas-up \
#     --ts-authkey 'tskey-auth-...' \
#     --ts-fqdn 'coas-matrix.tail12345.ts.net' \
#     --bot-password 'PASSWORD' \
#     --personal-user jim \
#     --personal-password 'PASSWORD'
#
# First run (non-interactive, JSON config — ideal for agents):
#   ./scripts/coas-up --config '{"ts_authkey":"tskey-auth-...","ts_fqdn":"coas-matrix.tail12345.ts.net","bot_password":"X","personal_user":"jim","personal_password":"Y"}'

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TOOLS_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
INFRA_DIR="${TOOLS_DIR}/coas-infra"
SECRETS="${COAS_SECRETS_WRAPPER:-${SCRIPT_DIR}/coas-secrets}"

# ── Parse args ───────────────────────────────────────────────────

BUILD=""
BOOTSTRAP_ARGS=()
COMPOSE_ARGS=()
ARG_TS_AUTHKEY=""
ARG_TS_FQDN=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --build) BUILD=1; shift ;;
    --ts-authkey) ARG_TS_AUTHKEY="$2"; shift 2 ;;
    --ts-fqdn)   ARG_TS_FQDN="$2"; shift 2 ;;
    --bot-password|--personal-user|--personal-password|--bot-user|--room-name)
      BOOTSTRAP_ARGS+=("$1" "$2"); shift 2 ;;
    --config)
      # JSON config — parse all fields at once (agent-friendly).
      # Writes a temp shell fragment and sources it to avoid nested quoting.
      _cfg_tmp="$(mktemp)"
      python3 - "$2" <<'PYEOF' > "${_cfg_tmp}"
import json, sys, shlex
c = json.loads(sys.argv[1])
q = shlex.quote
for key, var in [("ts_authkey", "ARG_TS_AUTHKEY"), ("ts_fqdn", "ARG_TS_FQDN")]:
    v = c.get(key)
    if v: print(var + "=" + q(v))
ba = []
for key, flag in [("bot_password","--bot-password"),("personal_user","--personal-user"),
                   ("personal_password","--personal-password"),("bot_user","--bot-user"),
                   ("room_name","--room-name")]:
    v = c.get(key)
    if v: ba += [flag, q(v)]
if ba: print("BOOTSTRAP_ARGS=(" + " ".join(ba) + ")")
PYEOF
      # shellcheck disable=SC1090
      source "${_cfg_tmp}"
      rm -f "${_cfg_tmp}"
      shift 2 ;;
    -h|--help)
      sed -n '2,/^$/{ s/^# //; s/^#//; p; }' "$0"
      exit 0 ;;
    *) COMPOSE_ARGS+=("$1"); shift ;;
  esac
done

# ── Ensure prerequisites ─────────────────────────────────────────

ensure_secret() {
  local key="$1" label="$2" hint="$3" value="${4:-}"
  if "${SECRETS}" get "${key}" >/dev/null 2>&1; then
    return 0
  fi
  if [[ -n "${value}" ]]; then
    echo "${value}" | "${SECRETS}" set "${key}"
    echo "coas-up: ✓ stored ${key}" >&2
    return 0
  fi
  echo "" >&2
  echo "coas-up: ${label} not found in secret store." >&2
  echo "  ${hint}" >&2
  echo "" >&2
  read -rsp "  Paste ${label} (input hidden): " value
  echo "" >&2
  if [[ -z "${value}" ]]; then
    echo "coas-up: error — ${label} is required" >&2
    exit 1
  fi
  echo "${value}" | "${SECRETS}" set "${key}"
  echo "coas-up: ✓ stored ${key}" >&2
}

ensure_env_file() {
  local env_file="${INFRA_DIR}/.env"
  if [[ -f "${env_file}" ]] && grep -q "^TS_FQDN=" "${env_file}" 2>/dev/null; then
    return 0
  fi

  local ts_fqdn="${ARG_TS_FQDN}"
  if [[ -z "${ts_fqdn}" ]]; then
    echo "" >&2
    echo "coas-up: .env needs TS_FQDN (your Tailscale Matrix hostname)." >&2
    echo "  Format: coas-matrix.<tailnet>.ts.net" >&2
    echo "  Find your tailnet name at https://login.tailscale.com/admin/dns" >&2
    echo "" >&2
    read -rp "  TS_FQDN: " ts_fqdn
    if [[ -z "${ts_fqdn}" ]]; then
      echo "coas-up: error — TS_FQDN is required" >&2
      exit 1
    fi
  fi

  cat > "${env_file}" <<EOF
# Generated by coas-up. Safe to edit.
TS_HOSTNAME=coas-matrix
TS_FQDN=${ts_fqdn}
KANBAN_WIP_LIMIT=3
EOF
  chmod 600 "${env_file}"
  echo "coas-up: ✓ wrote ${env_file}" >&2
}

# 1. Tailscale auth key
ensure_secret "tailscale-authkey" "Tailscale auth key" \
  "Generate one at https://login.tailscale.com/admin/settings/keys" \
  "${ARG_TS_AUTHKEY}"

# 2. .env with TS_FQDN
ensure_env_file

# ── Resolve secrets and env vars ─────────────────────────────────

# shellcheck disable=SC1091
source "${SCRIPT_DIR}/_resolve-env.sh"

# ── Generate continuwuity.toml from template ─────────────────────

TOML="${INFRA_DIR}/config/continuwuity.toml"
TOML_EXAMPLE="${INFRA_DIR}/config/continuwuity.toml.example"
if [[ ! -f "${TOML}" ]]; then
  sed "s/coas-matrix\.CHANGE-ME\.ts\.net/${TS_FQDN}/g" "${TOML_EXAMPLE}" > "${TOML}"
  echo "coas-up: ✓ generated continuwuity.toml from template" >&2
fi

echo "coas-up: starting stack..." >&2
echo "  TS_FQDN:   ${TS_FQDN}" >&2
echo "" >&2

# ── Build if requested ───────────────────────────────────────────

if [[ -n "${BUILD}" ]]; then
  echo "coas-up: rebuilding coas-agent image..." >&2
  docker compose build coas-agent
fi

# ── Start containers ─────────────────────────────────────────────

docker compose up -d "${COMPOSE_ARGS[@]+"${COMPOSE_ARGS[@]}"}"

# ── Configure Tailscale Serve (idempotent) ───────────────────────

TS_CONTAINER="coas-infra-tailscale-1"

echo "coas-up: waiting for Tailscale..." >&2
for _i in $(seq 1 30); do
  if docker exec "${TS_CONTAINER}" tailscale status >/dev/null 2>&1; then
    break
  fi
  sleep 2
done

if ! docker exec "${TS_CONTAINER}" tailscale serve status 2>/dev/null | grep -q "https://"; then
  echo "coas-up: configuring Tailscale Serve (HTTPS:443 → HTTP:80)..." >&2
  docker exec "${TS_CONTAINER}" tailscale serve --bg --https=443 http://127.0.0.1:80 >/dev/null 2>&1
fi

# ── Wait for HTTPS health ────────────────────────────────────────

echo "coas-up: waiting for HTTPS..." >&2

# Caddy may need a kick if it started before Tailscale Serve was ready
if ! curl -sf "https://${TS_FQDN}/" >/dev/null 2>&1; then
  docker restart coas-infra-caddy-1 >/dev/null 2>&1
  sleep 2
fi

for _i in $(seq 1 15); do
  if curl -sf "https://${TS_FQDN}/_matrix/client/versions" >/dev/null 2>&1; then
    echo "coas-up: ✓ HTTPS healthy" >&2
    break
  fi
  sleep 2
done

# ── Auto-bootstrap if needed ─────────────────────────────────────

if ! "${SECRETS}" get matrix-token >/dev/null 2>&1; then
  # Need bootstrap — check if we have the required args
  if [[ ${#BOOTSTRAP_ARGS[@]} -eq 0 ]]; then
    echo "" >&2
    echo "coas-up: first run — Matrix needs bootstrapping." >&2

    # Prompt interactively
    read -rp "  Bot password: " bot_pw
    read -rp "  Personal username (e.g. jim): " personal_user
    read -rp "  Personal password: " personal_pw

    if [[ -z "${bot_pw}" || -z "${personal_user}" || -z "${personal_pw}" ]]; then
      echo "coas-up: error — all three are required" >&2
      exit 1
    fi

    BOOTSTRAP_ARGS=(
      --bot-password "${bot_pw}"
      --personal-user "${personal_user}"
      --personal-password "${personal_pw}"
    )
  fi

  echo "" >&2
  "${SCRIPT_DIR}/coas-bootstrap-matrix" "${BOOTSTRAP_ARGS[@]}"
fi

# ── Done ─────────────────────────────────────────────────────────

echo "" >&2
echo "coas-up: ✓ stack ready" >&2
echo "  make attach    # start pi in the container" >&2
echo "  make logs      # tail logs" >&2
echo "  make down      # stop the stack" >&2
