#!/usr/bin/env bash
#
# coas-bootstrap-matrix — one-shot Matrix provisioning for the CoAS stack.
#
# Called automatically by coas-up on first run (when matrix-token is not
# in the secret store). Can also be run manually.
#
# Flow:
#   1. Extract Continuwuity's auto-generated registration token from logs
#   2. Register bot as the first user (using that token)
#   3. Store bot token + password in the host secret store
#   4. Create personal user via admin room (bot is admin as first user)
#   5. Create private encrypted room with correct power levels
#   6. Update coas/.pi/settings.json
#
# No TOML editing, no sed, no config restarts. Continuwuity auto-closes
# registration after the first user is created.

set -euo pipefail

# ── Parse args ────────────────────────────────────────────────────

BOT_USER="coas-bot"
PERSONAL_USER=""
BOT_PASSWORD=""
PERSONAL_PASSWORD=""
ROOM_NAME="Chief of Staff"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --bot-user)          BOT_USER="$2"; shift 2 ;;
    --bot-password)      BOT_PASSWORD="$2"; shift 2 ;;
    --personal-user)     PERSONAL_USER="$2"; shift 2 ;;
    --personal-password) PERSONAL_PASSWORD="$2"; shift 2 ;;
    --room-name)         ROOM_NAME="$2"; shift 2 ;;
    -h|--help)
      cat <<'USAGE'
usage: coas-bootstrap-matrix \
  --bot-password 'PASSWORD' \
  --personal-user jim \
  --personal-password 'PASSWORD' \
  [--room-name 'Chief of Staff'] \
  [--bot-user coas-bot]

Provisions both Matrix accounts, creates a private encrypted room,
and updates coas/.pi/settings.json. Run once after infra is up.
USAGE
      exit 0
      ;;
    *) echo "unknown arg: $1" >&2; exit 1 ;;
  esac
done

if [[ -z "${BOT_PASSWORD}" ]]; then echo "error: --bot-password is required" >&2; exit 1; fi
if [[ -z "${PERSONAL_USER}" ]]; then echo "error: --personal-user is required" >&2; exit 1; fi
if [[ -z "${PERSONAL_PASSWORD}" ]]; then echo "error: --personal-password is required" >&2; exit 1; fi

# ── Resolve env ───────────────────────────────────────────────────

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TOOLS_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
COAS_DIR="${COAS_DIR:-${TOOLS_DIR}/../coas}"
export COAS_QUIET=1
# shellcheck disable=SC1091
source "${SCRIPT_DIR}/_resolve-env.sh"

SECRETS="${COAS_SECRETS_WRAPPER:-${SCRIPT_DIR}/coas-secrets}"
HOMESERVER="https://${TS_FQDN}"
SETTINGS="${COAS_DIR}/.pi/settings.json"
CONTAINER="coas-infra-continuwuity-1"

echo "" >&2
echo "╔═══════════════════════════════════════════════════════════╗" >&2
echo "║  coas-bootstrap-matrix                                   ║" >&2
echo "║  Provisioning accounts + room on ${TS_FQDN}" >&2
echo "╚═══════════════════════════════════════════════════════════╝" >&2
echo "" >&2

# ── Helper: wait for HTTPS endpoint ──────────────────────────────

wait_for_https() {
  local url="$1" max_attempts="${2:-20}"
  local i=0
  while ! curl -sf "${url}" >/dev/null 2>&1; do
    i=$((i + 1))
    if [[ $i -ge $max_attempts ]]; then
      echo "  error: ${url} not reachable after ${max_attempts} attempts" >&2
      return 1
    fi
    sleep 2
  done
}

# ── Helper: send admin command and get response ──────────────────

admin_command() {
  local token="$1" admin_room="$2" command="$3"
  local txn response attempt
  txn="$(uuidgen)"

  curl -sf -X PUT \
    -H "Authorization: Bearer ${token}" \
    -H "Content-Type: application/json" \
    "${HOMESERVER}/_matrix/client/v3/rooms/${admin_room}/send/m.room.message/${txn}" \
    -d "{\"msgtype\": \"m.text\", \"body\": \"!admin ${command}\"}" >/dev/null 2>&1

  # Poll for the conduit bot's response (up to 10s)
  for attempt in $(seq 1 10); do
    sleep 1
    response="$(curl -sf -H "Authorization: Bearer ${token}" \
      "${HOMESERVER}/_matrix/client/v3/rooms/${admin_room}/messages?dir=b&limit=3" 2>/dev/null \
      | python3 -c "
import json, sys
data = json.load(sys.stdin)
for event in data.get('chunk', []):
    sender = event.get('sender', '')
    body = event.get('content', {}).get('body', '')
    # Skip our own command and empty responses
    if sender.startswith('@conduit') and body:
        print(body)
        break
" 2>/dev/null)"
    if [[ -n "${response}" ]]; then
      echo "${response}"
      return 0
    fi
  done
  echo "error: no response from admin bot after 10s" >&2
  return 1
}

# ── Step 1: Extract registration token from logs ──────────────────

echo "Step 1/6: Getting registration token from Continuwuity..." >&2

wait_for_https "${HOMESERVER}/_matrix/client/versions"

# Continuwuity prints its auto-generated token on first boot
REG_TOKEN="$(docker logs "${CONTAINER}" 2>&1 \
  | grep -o 'using the registration token [^ ]*' \
  | tail -1 \
  | sed 's/.*token //' \
  | sed 's/\x1b\[[0-9;]*m//g')"

if [[ -z "${REG_TOKEN}" ]]; then
  echo "  error: could not find registration token in Continuwuity logs" >&2
  echo "  hint: is this a fresh Continuwuity database?" >&2
  exit 1
fi
echo "  ✓ Token extracted" >&2

# ── Step 2: Register bot (first user = admin) ────────────────────

echo "Step 2/6: Registering @${BOT_USER}:${TS_FQDN}..." >&2

BOT_RESPONSE="$(curl -sf -X POST "${HOMESERVER}/_matrix/client/v3/register" \
  -H "Content-Type: application/json" \
  -d "{
    \"username\": \"${BOT_USER}\",
    \"password\": \"${BOT_PASSWORD}\",
    \"auth\": {
      \"type\": \"m.login.registration_token\",
      \"token\": \"${REG_TOKEN}\"
    }
  }" 2>&1)" || {
  echo "  error: bot registration failed" >&2
  echo "  response: ${BOT_RESPONSE}" >&2
  exit 1
}

BOT_ACCESS_TOKEN="$(echo "${BOT_RESPONSE}" | python3 -c "import sys,json; print(json.load(sys.stdin)['access_token'])" 2>/dev/null)" || {
  echo "  error: no access_token in response: ${BOT_RESPONSE}" >&2
  exit 1
}

echo "  ✓ Bot registered (admin)" >&2

# Store credentials
echo "${BOT_ACCESS_TOKEN}" | "${SECRETS}" set matrix-token
echo "${BOT_PASSWORD}" | "${SECRETS}" set bot-password
echo "  ✓ Credentials stored" >&2

# ── Step 3: Create personal user via admin room ───────────────────

echo "Step 3/6: Creating @${PERSONAL_USER}:${TS_FQDN} via admin room..." >&2

# Find the admin room (room with @conduit)
ADMIN_ROOM="$(curl -sf -H "Authorization: Bearer ${BOT_ACCESS_TOKEN}" \
  "${HOMESERVER}/_matrix/client/v3/joined_rooms" 2>/dev/null \
  | python3 -c "
import json, sys
rooms = json.load(sys.stdin).get('joined_rooms', [])
for room in rooms:
    print(room)
" 2>/dev/null | head -1)"

if [[ -z "${ADMIN_ROOM}" ]]; then
  echo "  error: could not find admin room" >&2
  exit 1
fi

ADMIN_RESULT="$(admin_command "${BOT_ACCESS_TOKEN}" "${ADMIN_ROOM}" \
  "users create-user ${PERSONAL_USER} ${PERSONAL_PASSWORD}")"

if echo "${ADMIN_RESULT}" | grep -q "Created user"; then
  echo "  ✓ Personal account created" >&2
else
  echo "  error: ${ADMIN_RESULT}" >&2
  exit 1
fi

# Get personal user's access token by logging in
PERSONAL_TOKEN="$(curl -sf -X POST "${HOMESERVER}/_matrix/client/v3/login" \
  -H "Content-Type: application/json" \
  -d "{
    \"type\": \"m.login.password\",
    \"identifier\": {\"type\": \"m.id.user\", \"user\": \"${PERSONAL_USER}\"},
    \"password\": \"${PERSONAL_PASSWORD}\"
  }" | python3 -c "import sys,json; print(json.load(sys.stdin)['access_token'])" 2>/dev/null)"

echo "  ✓ Personal account ready" >&2

# ── Step 4: Create private encrypted room ─────────────────────────

echo "Step 4/6: Creating room '${ROOM_NAME}'..." >&2

# Create as personal user (higher power level)
ROOM_RESPONSE="$(curl -sf -X POST "${HOMESERVER}/_matrix/client/v3/createRoom" \
  -H "Authorization: Bearer ${PERSONAL_TOKEN}" \
  -H "Content-Type: application/json" \
  -d "{
    \"name\": \"${ROOM_NAME}\",
    \"preset\": \"private_chat\",
    \"visibility\": \"private\",
    \"invite\": [\"@${BOT_USER}:${TS_FQDN}\"],
    \"initial_state\": [
      {
        \"type\": \"m.room.encryption\",
        \"content\": {\"algorithm\": \"m.megolm.v1.aes-sha2\"}
      }
    ]
  }" 2>&1)" || {
  echo "  error: room creation failed: ${ROOM_RESPONSE}" >&2
  exit 1
}

ROOM_ID="$(echo "${ROOM_RESPONSE}" | python3 -c "import sys,json; print(json.load(sys.stdin)['room_id'])" 2>/dev/null)"
echo "  ✓ Room created: ${ROOM_ID}" >&2

# Set power levels
curl -sf -X PUT \
  -H "Authorization: Bearer ${PERSONAL_TOKEN}" \
  -H "Content-Type: application/json" \
  "${HOMESERVER}/_matrix/client/v3/rooms/${ROOM_ID}/state/m.room.power_levels/" \
  -d "{
    \"users\": {
      \"@${PERSONAL_USER}:${TS_FQDN}\": 100,
      \"@${BOT_USER}:${TS_FQDN}\": 50
    },
    \"users_default\": 0, \"events_default\": 0,
    \"state_default\": 50, \"ban\": 50, \"kick\": 50,
    \"redact\": 50, \"invite\": 50
  }" >/dev/null 2>&1

# Bot joins the room
curl -sf -X POST "${HOMESERVER}/_matrix/client/v3/join/${ROOM_ID}" \
  -H "Authorization: Bearer ${BOT_ACCESS_TOKEN}" \
  -H "Content-Type: application/json" \
  -d '{}' >/dev/null 2>&1
echo "  ✓ Bot joined room" >&2

# ── Step 5: Update settings.json ──────────────────────────────────

echo "Step 5/6: Updating ${SETTINGS}..." >&2

mkdir -p "$(dirname "${SETTINGS}")"

python3 -c "
import json, sys, os
path = sys.argv[1]
room_id = sys.argv[2]
ts_fqdn = sys.argv[3]
bot_user = sys.argv[4]
tools_dir = sys.argv[5]

data = {}
if os.path.exists(path):
    with open(path) as f:
        data = json.load(f)

# Extension paths derived from tools dir
kanban_ext = os.path.join(tools_dir, 'project-extensions', 'kanban')
matrix_ext = os.path.join(tools_dir, 'project-extensions', 'matrix')

data['extensions'] = [kanban_ext, matrix_ext]
data['matrix'] = {
    'homeserver': f'https://{ts_fqdn}',
    'userId': f'@{bot_user}:{ts_fqdn}',
    'roomId': room_id,
    'targetAgent': 'coas',
    'accessTokenEnv': 'MATRIX_ACCESS_TOKEN',
    'botPasswordEnv': 'MATRIX_BOT_PASSWORD',
    'encryption': True,
    'deviceDisplayName': 'CoAS Chief of Staff (extension)',
    'cryptoStorePath': '~/.pi/agent/matrix-crypto'
}

with open(path, 'w') as f:
    json.dump(data, f, indent=2)
    f.write('\n')
" "${SETTINGS}" "${ROOM_ID}" "${TS_FQDN}" "${BOT_USER}" "${TOOLS_DIR}"

echo "  ✓ settings.json updated" >&2

# ── Step 6: Done ──────────────────────────────────────────────────

echo "" >&2
echo "╔═══════════════════════════════════════════════════════════╗" >&2
echo "║  Bootstrap complete!                                     ║" >&2
echo "╠═══════════════════════════════════════════════════════════╣" >&2
echo "║  Bot:   @${BOT_USER}:${TS_FQDN}" >&2
echo "║  You:   @${PERSONAL_USER}:${TS_FQDN}" >&2
echo "║  Room:  ${ROOM_ID}" >&2
echo "║                                                          ║" >&2
echo "║  Sign in to Element X:                                   ║" >&2
echo "║    Homeserver: ${HOMESERVER}" >&2
echo "║    User: ${PERSONAL_USER}                                ║" >&2
echo "╚═══════════════════════════════════════════════════════════╝" >&2
