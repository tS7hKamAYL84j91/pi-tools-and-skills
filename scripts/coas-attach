#!/usr/bin/env bash
#
# coas-attach — docker exec into the coas-agent container and start pi.
# This is the normal way to talk to the Chief of Staff.
#
# Pi is interactive (TUI), so we need a TTY. The container's working
# directory is /workspace/coas, so pi finds the coas workspace
# automatically and loads the project's .pi/settings.json.

set -euo pipefail

# Resolve env so docker compose can parse the compose file.
export COAS_QUIET=1
# shellcheck disable=SC1091
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/_resolve-env.sh"

docker compose exec -it coas-agent pi "$@"
