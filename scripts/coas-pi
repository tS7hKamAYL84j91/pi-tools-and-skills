#!/usr/bin/env bash
#
# coas-pi — start pi in the coas workspace with secrets resolved.
#
# Resolves MATRIX_ACCESS_TOKEN, MATRIX_BOT_PASSWORD, and
# MATRIX_RECOVERY_PASSPHRASE from the host secret store, then
# exec's pi. Use this (or `make pi`) instead of bare `pi` when
# running on the host with Matrix enabled.
#
# Usage:
#   make pi
#   scripts/coas-pi
#   COAS_DIR=~/git/other-workspace scripts/coas-pi

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TOOLS_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
COAS_DIR="${COAS_DIR:-${TOOLS_DIR}/../coas}"
SECRETS="${COAS_SECRETS_WRAPPER:-${SCRIPT_DIR}/coas-secrets}"

if [[ ! -x "${SECRETS}" ]]; then
  echo "coas-pi: cannot find coas-secrets at ${SECRETS}" >&2
  exit 1
fi

# Resolve matrix token from secret store (soft — pi works without matrix)
if MATRIX_ACCESS_TOKEN="$("${SECRETS}" get matrix-token 2>/dev/null)"; then
  export MATRIX_ACCESS_TOKEN
else
  echo "coas-pi: warning — matrix-token not in secret store, matrix extension will be disabled" >&2
fi

# Bot password for cross-signing UIA
if MATRIX_BOT_PASSWORD="$("${SECRETS}" get bot-password 2>/dev/null)"; then
  export MATRIX_BOT_PASSWORD
fi

# Optional Secure Backup recovery passphrase
if MATRIX_RECOVERY_PASSPHRASE="$("${SECRETS}" get matrix-recovery 2>/dev/null)"; then
  export MATRIX_RECOVERY_PASSPHRASE
fi

cd "${COAS_DIR}"
exec pi "$@"
