#!/usr/bin/env bash
#
# coas-stack — start the CoAS stack, supervise it, gracefully tear it down.
#
# Single foreground script that:
#   1. Resolves all secrets from the host secret store (Keychain on macOS,
#      pass on Linux) via the coas-secrets wrapper
#   2. Validates required env vars (TS_FQDN, GIT_ROOT etc.) and aborts
#      with a clear error if anything is missing
#   3. Brings up the four containers via `docker compose up -d`
#   4. Streams `docker compose logs -f` to stdout (so the user sees live
#      output from all services)
#   5. Monitors container health every 15 seconds. If any service is in a
#      non-running state (Exited, Restarting, OOMKilled, Created), attempts
#      to restart it via `docker compose start` (or `up -d` as a fallback)
#   6. Tracks restart attempts per service. If a service restarts more
#      than RESTART_LIMIT times within RESTART_WINDOW seconds, the supervisor
#      gives up on that service and logs a critical error (manual intervention
#      required) — prevents pathological restart loops
#   7. On SIGINT (Ctrl+C), SIGTERM, or normal exit: kills the background
#      log tail, runs `docker compose down` for graceful shutdown (10s
#      SIGTERM grace period before SIGKILL), and exits cleanly
#
# Usage:
#   ./scripts/coas-stack            # foreground supervisor
#   ./scripts/coas-stack --build    # rebuild coas-agent image first
#
# This is intended for both interactive use (run in a terminal, Ctrl+C to
# stop) and as a systemd/launchd unit ExecStart command (the script will
# also handle SIGTERM cleanly).
#
# For the simpler "detached, no supervisor" case, use ./scripts/coas-up
# instead. That returns immediately after `docker compose up -d`.

set -euo pipefail

# ── Configuration ─────────────────────────────────────────────────

INFRA_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../coas-infra" && pwd)"
HEALTH_INTERVAL=15            # seconds between health checks
RESTART_LIMIT=3               # max restarts per service in RESTART_WINDOW
RESTART_WINDOW=300            # rolling window in seconds (5 min)

# Tracked across the loop
LOG_TAIL_PID=""
STACK_STARTED=0   # set to 1 after `docker compose up -d` succeeds

# Per-service state is held in dynamically-named variables (rather than
# associative arrays) so this script works on bash 3.2 (macOS default)
# AND bash 4+ (Linux DGX). Service name → variable name uses underscores
# in place of hyphens. Two namespaces:
#
#   restart_times_<svc>  — space-separated unix timestamps of recent restarts
#   gave_up_<svc>        — "1" if the supervisor has stopped restarting this service

# ── Helpers ───────────────────────────────────────────────────────

log() {
  printf '[%s] coas-stack: %s\n' "$(date '+%H:%M:%S')" "$*" >&2
}

# Convert a service name (e.g. "coas-agent") to a safe variable suffix
# (e.g. "coas_agent"). bash variable names cannot contain hyphens.
svc_to_var() {
  echo "$1" | tr '-' '_'
}

is_too_many_restarts() {
  local svc="$1"
  local var
  var="restart_times_$(svc_to_var "${svc}")"
  local now
  now="$(date +%s)"
  local cutoff=$((now - RESTART_WINDOW))
  local recent=""
  local count=0
  # Indirect expansion via eval, since ${!var} doesn't expand inside arithmetic
  local existing
  eval "existing=\"\${${var}:-}\""
  for t in ${existing}; do
    if (( t > cutoff )); then
      recent="${recent} ${t}"
      count=$((count + 1))
    fi
  done
  eval "${var}='${recent}'"
  (( count >= RESTART_LIMIT ))
}

record_restart() {
  local svc="$1"
  local var
  var="restart_times_$(svc_to_var "${svc}")"
  local now
  now="$(date +%s)"
  local existing
  eval "existing=\"\${${var}:-}\""
  eval "${var}='${existing} ${now}'"
}

restart_count() {
  local svc="$1"
  local var
  var="restart_times_$(svc_to_var "${svc}")"
  local existing
  eval "existing=\"\${${var}:-}\""
  echo "${existing}" | wc -w | tr -d ' '
}

is_given_up() {
  local svc="$1"
  local var
  var="gave_up_$(svc_to_var "${svc}")"
  local val
  eval "val=\"\${${var}:-0}\""
  [[ "${val}" == "1" ]]
}

mark_given_up() {
  local svc="$1"
  local var
  var="gave_up_$(svc_to_var "${svc}")"
  eval "${var}=1"
}

# ── Cleanup (signal trap) ─────────────────────────────────────────

cleanup() {
  local exit_code=$?
  trap - EXIT INT TERM   # disarm to prevent re-entry

  echo "" >&2
  log "shutting down..."

  # Kill the background log tail if it's still running
  if [[ -n "${LOG_TAIL_PID}" ]] && kill -0 "${LOG_TAIL_PID}" 2>/dev/null; then
    kill "${LOG_TAIL_PID}" 2>/dev/null || true
    wait "${LOG_TAIL_PID}" 2>/dev/null || true
  fi

  # Bring down the stack gracefully if we ever started it. Docker compose
  # sends SIGTERM to each container, waits up to 15s for clean shutdown,
  # then SIGKILL. Volumes persist (we deliberately don't pass -v).
  if [[ "${STACK_STARTED}" == "1" ]]; then
    cd "${INFRA_DIR}"
    if docker compose down --timeout 15 2>&1 | tail -15 >&2; then
      log "stopped cleanly."
    else
      log "warning: docker compose down reported errors (see above)"
    fi
  fi

  exit "${exit_code}"
}

trap cleanup EXIT INT TERM

# ── Resolve secrets and env vars (sourced lib) ────────────────────

log "resolving secrets..."

# shellcheck disable=SC1091
source "$(dirname "${BASH_SOURCE[0]}")/_resolve-env.sh"

# ── Bring up the stack ────────────────────────────────────────────

cd "${INFRA_DIR}"

if [[ "${1:-}" == "--build" ]]; then
  log "rebuilding coas-agent image..."
  docker compose build coas-agent
  shift
fi

log "starting stack..."
log "  TS_FQDN:       ${TS_FQDN}"
log "  GIT_ROOT:      ${GIT_ROOT}"
log "  PI_STATE_DIR:  ${PI_STATE_DIR}"

if ! docker compose up -d "$@"; then
  log "ERROR: docker compose up failed"
  exit 1
fi
STACK_STARTED=1

log "stack started — $(docker compose ps --format '{{.Service}}' | wc -l | tr -d ' ') services"
log "supervising; ctrl+c to stop and clean up"
echo "" >&2

# ── Stream logs in the background ────────────────────────────────

docker compose logs -f --tail 20 &
LOG_TAIL_PID=$!

# ── Health monitoring loop ────────────────────────────────────────

while true; do
  sleep "${HEALTH_INTERVAL}"

  # If the log tail died for some reason (compose was restarted out of band,
  # the file handle closed, etc.), restart it so we keep seeing output.
  if [[ -n "${LOG_TAIL_PID}" ]] && ! kill -0 "${LOG_TAIL_PID}" 2>/dev/null; then
    log "log tail process died, restarting..."
    docker compose logs -f --tail 0 &
    LOG_TAIL_PID=$!
  fi

  # Check container states. docker compose ps with --format gives us
  # parseable output. State values include: running, exited, restarting,
  # paused, dead, created.
  if ! states="$(docker compose ps --format '{{.Service}} {{.State}}' 2>/dev/null)"; then
    log "warning: docker compose ps failed — docker daemon may be down"
    continue
  fi

  while IFS= read -r line; do
    [[ -z "${line}" ]] && continue
    svc="${line%% *}"
    state="${line#* }"

    if [[ "${state}" == "running" ]]; then
      continue
    fi

    if is_given_up "${svc}"; then
      # Already gave up on this service — only log periodically (once per check)
      log "service '${svc}' is ${state} (manual intervention required — restart limit exceeded)"
      continue
    fi

    if is_too_many_restarts "${svc}"; then
      mark_given_up "${svc}"
      log "CRITICAL: service '${svc}' has been restarted ${RESTART_LIMIT}+ times in ${RESTART_WINDOW}s — giving up"
      log "          fix the underlying issue and re-run coas-stack to clear the limit"
      continue
    fi

    record_restart "${svc}"
    log "service '${svc}' is ${state} — restarting (attempt $(restart_count "${svc}")/${RESTART_LIMIT})"

    if docker compose start "${svc}" >/dev/null 2>&1; then
      log "  → ${svc} restarted via 'compose start'"
    elif docker compose up -d "${svc}" >/dev/null 2>&1; then
      log "  → ${svc} (re)created via 'compose up -d'"
    else
      log "  → FAILED to restart ${svc}"
    fi
  done <<< "${states}"
done
